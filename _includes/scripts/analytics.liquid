{% if site.enable_google_analytics %}
  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.google_analytics }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.google_analytics }}');
  </script>
{% endif %}

{% if site.enable_cronitor_analytics %}
  <script
    async
    src="https://rum.cronitor.io/script.js"
    data-cronitor-key="{{ site.cronitor_analytics }}"
  ></script>
{% endif %}

{% if site.enable_pirsch_analytics %}
  <script
    defer
    src="https://api.pirsch.io/pa.js"
    id="pianjs"
    data-code="{{ site.pirsch_analytics }}"
  ></script>
{% endif %}

{% if site.enable_goatcounter %}
  <script
    data-goatcounter="https://{{ site.goatcounter_code }}.goatcounter.com/count"
    async
    src="//gc.zgo.at/count.js"
  ></script>
  <script>
    (function () {
      async function loadGoatCounterText() {
        const el = document.getElementById("gc-visit-text");
        if (!el) return;
        try {
          const response = await fetch(
            "https://{{ site.goatcounter_code }}.goatcounter.com/counter/TOTAL.json",
          );
          if (!response.ok) throw new Error("Failed to fetch counter");
          const data = await response.json();
          const count = data.count ?? 0;
          el.textContent = " · Views: " + count;
        } catch (err) {
          console.error("GoatCounter text counter error:", err);
        }
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadGoatCounterText);
      } else {
        loadGoatCounterText();
      }
    })();
  </script>
{% endif %}
