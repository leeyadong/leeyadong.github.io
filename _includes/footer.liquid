{% if site.footer_fixed %}
  <footer class="fixed-bottom">
    <div class="container mt-0">
      © Copyright {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}.
      {{ site.footer_text }}
      {% if site.impressum_path %}
        <a href="{{ site.impressum_path | relative_url }}">Impressum</a>.
      {% endif %}
      {% if site.last_updated %}
        Last updated: {{ 'now' | date: '%B %d, %Y' }}.
      {% endif %}
      <span id="gc-visit-text"></span>
    </div>
  </footer>
{% else %}
  {% if site.newsletter.enabled %}
    {% include scripts/newsletter.liquid %}
  {% endif %}
  <footer class="sticky-bottom mt-5">
    <div class="container">
      © Copyright {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}.
      {{ site.footer_text }}
      {% if site.impressum_path %}
        <a href="{{ site.impressum_path | relative_url }}">Impressum</a>.
      {% endif %}
      {% if site.last_updated %}
        Last updated: {{ 'now' | date: '%B %d, %Y' }}.
      {% endif %}
      <span id="gc-visit-text"></span>
    </div>
  </footer>
{% endif %}
